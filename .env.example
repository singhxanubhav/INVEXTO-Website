# Database
DATABASE_URL=postgresql://user:password@host:5432/invexto

# Auth
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRY=7d

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stock microservice
STOCK_MICROSERVICE_URL=http://localhost:8000

# Contact form - admin email to receive contact messages
CONTACT_EMAIL=admin@invexto.in

# Public contact details (shown on contact page)
NEXT_PUBLIC_CONTACT_EMAIL=your@email.com
NEXT_PUBLIC_CONTACT_PHONE=+91XXXXXXXXXX

# SMTP config (for contact form emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here